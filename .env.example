# example for locally run instance: postgresql://postgres:postgres@localhost:5432/konzisite?schema=public
DATABASE_URL="postgresql://<username>:<password>@<host>:<port>/<database_name>?schema=<schema_name>"
DATABASE_PASSWORD=<change me in prod>
POSTGRES_PASSWORD=<same as above>
AUTHSCH_CLIENT_ID=<your client id>
AUTHSCH_CLIENT_SECRET=<your client secret>
